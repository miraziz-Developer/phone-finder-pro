# Application
APP_ENV=development
APP_DEBUG=false
APP_NAME=phone-marketplace-bot
DEFAULT_CURRENCY=USD

# Telegram
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_IDS=123456789,987654321

# FastAPI Admin API
API_ENABLED=true
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
JWT_SECRET_KEY=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
API_ADMIN_USERNAME=admin
API_ADMIN_PASSWORD=admin_secret_change_me

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=phonebot
POSTGRES_PASSWORD=phonebot_secret
POSTGRES_DB=phonebot

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
CACHE_TTL_SECONDS=300
CACHE_ENABLED=true

# Rate Limiting
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Pagination
PAGINATION_PAGE_SIZE=5
PAGINATION_MAX_PAGE_SIZE=50

# Recommendation Engine Weights (must sum to 1.0)
RECOMMENDATION_TOP_N=5
RECOMMENDATION_MIN_SCORE=0.3
SCORE_WEIGHT_BUDGET=0.30
SCORE_WEIGHT_PERFORMANCE=0.20
SCORE_WEIGHT_CAMERA=0.15
SCORE_WEIGHT_BATTERY=0.10
SCORE_WEIGHT_DISPLAY=0.10
SCORE_WEIGHT_STORAGE=0.05
SCORE_WEIGHT_BRAND=0.05
SCORE_WEIGHT_FEATURES=0.05
BUDGET_TOLERANCE_RATIO=0.15

# Compare
COMPARISON_MAX_PHONES=2

# Import
IMPORT_MAX_ROWS=500
IMPORT_BATCH_SIZE=50

# Budget Limits (USD)
MIN_BUDGET_USD=100
MAX_BUDGET_USD=5000
